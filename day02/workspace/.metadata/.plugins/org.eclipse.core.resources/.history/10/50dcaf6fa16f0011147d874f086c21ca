> 예외 클래스

  * Built-In 예외 클래스
    
    class TestCal {
	public static void main(String[] args) {
		try {
			int op1 = Integer.parseInt(args[0]);
			String op = args[1];
			int op2 = Integer.parseInt(args[2]);
		} catch(Exception e) {
		}
		
		if(op.equals("add")) {
			System.out.println(op1 + op2);
		} else if(op.equals("sub")) {
			System.out.println(op1 - op2);
		} else if(op.equals("mul")) {
			System.out.println(op1 * op2);
		} else if(op.equals("div")) {
			System.out.println(op1 / op2);
		}		
	}
    }
  
  
  * User-Defined 예외 클래스

    



