  1. 클래스 정의
     class Student { //헬퍼클래스
	private String name; //멤버필드
	public void setName(String name) {
		this.name = name;
	}
	public String getName() { //멤버메소드
		return name;
	}
     }
     
     class TestStudent { //실행클래스
	public static void main(String[] args) {
		Student st = new Student();
		st.setName("홍길동");
		System.out.println(st.getName());
	}
     }
  
  2. 객체참조변수 선언
     Student st
  
  3. 객체 생성
     new Student
  
  4. 생성자 호출
     new Student();
  
  5. 주소 할당
     Student st = new Student();
  
  6. 객체 사용
     st.setName("홍길동");
     st.getName()
     
  7. 객체 소멸
     st = null;
     }


